# ── Database ─────────────────────────────────────────────────────
# Free PostgreSQL: https://neon.tech  or  https://supabase.com
DATABASE_URL="postgresql://user:password@host/dataproof?sslmode=require"

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET="generate-a-random-64-char-string-here"

# ── Shelby Storage (from shelby.xyz Early Access) ─────────────────
SHELBY_ENDPOINT="https://s3.shelby.xyz"
SHELBY_ACCESS_KEY="your-shelby-access-key"
SHELBY_SECRET_KEY="your-shelby-secret-key"
SHELBY_BUCKET="dataproof-datasets"
SHELBY_REGION="global"

# ── Aptos Testnet ─────────────────────────────────────────────────
APTOS_NODE_URL="https://api.testnet.aptoslabs.com/v1"
APTOS_INDEXER_URL="https://api.testnet.aptoslabs.com/v1/graphql"
APTOS_MODULE_ADDRESS="0xYOUR_MODULE_ADDRESS"
APTOS_PRIVATE_KEY="your-aptos-private-key"
